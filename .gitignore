```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
*.class
*.exe
*.dll
*.so
*.a
*.out

# Dependencies
vendor/
node_modules/
.env
.env.local
.env.*

# Logs and temp files
*.log
*.tmp
*.swp
*.swo

# Editors
.vscode/
.idea/

# Coverage and testing
.coverage
coverage/
htmlcov/

# OS specific
.DS_Store
Thumbs.db

# Build directories
dist/
build/
target/
.gradle/

# Python specific
*.pyc
__pycache__/
*.pyo
*.pyd
.Python
*.so
.PyInstaller/
.pytest_cache/
.mypy_cache/
.tox/
.coverage*

# PHP specific
*.php~
*.php.bak
*.phar
vendor/composer/
composer.lock

# Laravel specific (if applicable)
storage/
bootstrap/cache/
!.env.example
!.env
```